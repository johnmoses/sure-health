{
    "info": {
      "_postman_id": "ec0bedfc-f390-456b-9dbe-telemedicine-full",
      "name": "Telemedicine Healthcare API (Full Example)",
      "description": "Extensively detailed collection with environment & embedded tests",
      "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
    },
    "variable": [
      { "key": "base_url", "value": "http://localhost:5001", "description": "API base URL" },
      { "key": "jwt_token", "value": "" }
    ],
    "item": [
      {
        "name": "Auth",
        "item": [
          {
            "name": "Register User",
            "request": {
              "method": "POST",
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": { "mode": "raw", "raw": "{\n  \"username\": \"testuser\",\n  \"password\": \"testpass\",\n  \"role\": \"patient\"\n}" },
              "url": { "raw": "{{base_url}}/auth/register", "host": ["{{base_url}}"], "path": ["auth", "register"] }
            },
            "event": [{
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Response has 201 status', ()=>pm.response.to.have.status(201));",
                  "pm.test('User registered message', ()=>pm.expect(pm.response.json().msg).to.include('registered'));"
                ],
                "type": "text/javascript"
              }
            }]
          },
          {
            "name": "Login User",
            "request": {
              "method": "POST",
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": { "mode": "raw", "raw": "{\n  \"username\": \"testuser\",\n  \"password\": \"testpass\"\n}" },
              "url": { "raw": "{{base_url}}/auth/login", "host": ["{{base_url}}"], "path": ["auth", "login"] }
            },
            "event": [{
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Login successful', ()=>pm.response.to.have.status(200));",
                  "let json = pm.response.json();",
                  "pm.test('msg in response', ()=>pm.expect(json.msg).to.include('Login successful'));",
                  "// Save role (for chaining if needed)",
                  "pm.environment.set('user_role', json.role||'');"
                ],
                "type": "text/javascript"
              }
            }]
          }
        ]
      },
      {
        "name": "Appointments",
        "item": [
          {
            "name": "Create Appointment",
            "request": {
              "method": "POST",
              "header": [
                { "key": "Content-Type", "value": "application/json" },
                { "key": "Authorization", "value": "Bearer {{jwt_token}}" }
              ],
              "body": {
                "mode": "raw",
                "raw": "{\n  \"patient_id\": 1,\n  \"clinician_id\": 2,\n  \"scheduled_time\": \"2025-07-22T10:30:00Z\",\n  \"status\": \"scheduled\"\n}"
              },
              "url": { "raw": "{{base_url}}/appointments/", "host": ["{{base_url}}"], "path": ["appointments"] }
            },
            "event": [{
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Appointment created', ()=>pm.response.to.have.status(201));",
                  "let json=pm.response.json();",
                  "pm.environment.set('appointment_id', json.id || 1);"
                ],
                "type": "text/javascript"
              }
            }]
          },
          {
            "name": "List Appointments",
            "request": {
              "method": "GET",
              "header": [ { "key": "Authorization", "value": "Bearer {{jwt_token}}" } ],
              "url": { "raw": "{{base_url}}/appointments/", "host": ["{{base_url}}"], "path": ["appointments"] }
            },
            "event": [{
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Got appointment list', ()=>pm.response.to.have.status(200));",
                  "pm.test('Is array', ()=>Array.isArray(pm.response.json()));"
                ],
                "type": "text/javascript"
              }
            }]
          }
        ]
      },
      {
        "name": "Chat",
        "item": [
          {
            "name": "Create/Get Chat Room for Appointment",
            "request": {
              "method": "GET",
              "header": [{ "key": "Authorization", "value": "Bearer {{jwt_token}}" }],
              "url": {
                "raw": "{{base_url}}/chat/rooms/{{appointment_id}}",
                "host": ["{{base_url}}"],
                "path": ["chat", "rooms", "{{appointment_id}}"]
              }
            },
            "event": [{
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Response is 200', ()=>pm.response.to.have.status(200));",
                  "let json = pm.response.json();",
                  "pm.environment.set('chatroom_id', json.room_id);"
                ],
                "type": "text/javascript"
              }
            }]
          },
          {
            "name": "Send Message to Chat Room",
            "request": {
              "method": "POST",
              "header": [
                { "key": "Content-Type", "value": "application/json" },
                { "key": "Authorization", "value": "Bearer {{jwt_token}}" }
              ],
              "body": {
                "mode": "raw",
                "raw": "{\n  \"room\": {{chatroom_id}},\n  \"sender_id\": 1,\n  \"content\": \"Hello doctor!\"\n}"
              },
              "url": { "raw": "{{base_url}}/chat/send", "host": ["{{base_url}}"], "path": ["chat", "send"] }
            },
            "event": [{
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Message sent', ()=>pm.response.to.have.status(200));"
                ],
                "type": "text/javascript"
              }
            }]
          }
        ]
      },
